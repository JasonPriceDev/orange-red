{
  "name": "Orion Forge",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/orange-red",
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/.env"],
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"
  ],

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "github.vscode-github-actions",
        "Vizards.deepseek-v4-for-copilot",
        "selfagency.z-models-vscode",
        "andrewbutson.vscode-openai"
      ],
      "settings": {
        "deepseek-copilot.baseUrl": "https://api.deepseek.com",
        "deepseek-copilot.maxTokens": 0,
        "z-models.openrouter.apiKey": "${env:OPENROUTER_API_KEY}",
        "github.copilot.advanced.openAiApiKey": "${env:OPENAI_API_KEY}",
        "chat.defaultModel": "DeepSeek V4 Pro (deepseek)",
        "chat.exploreAgent.defaultModel": "DeepSeek V4 Pro (deepseek)",
        "github.copilot.selectedCompletionModel": "DeepSeek V4 Pro (deepseek)",
        "inlineChat.defaultModel": "DeepSeek V4 Pro (deepseek)",
        "chat.utilitySmallModel": "deepseek/deepseek-v4-flash",
        "workbench.browser.enableChatTools": true,
        "python.terminal.activateEnvironment": true
      }
    }
  },

  "postCreateCommand": "bash scripts/post-create.sh",

  "forwardPorts": [5432],

  "remoteEnv": {
    "DEEP_SEEK_API_KEY": "${containerEnv:DEEP_SEEK_API_KEY}",
    "OPENROUTER_API_KEY": "${containerEnv:OPENROUTER_API_KEY}",
    "OPENAI_API_KEY": "${containerEnv:OPENAI_API_KEY}",
    "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}"
  }
}