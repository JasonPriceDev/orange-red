OPENAI_API_KEY=your_openai_api_key_here
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
ORANGE_RED_ALLOWED_HOSTS=intranet.example
ORANGE_RED_BUNDLE_DIR=orange-red-data
ORANGE_RED_DEPTH_LIMIT=2
ORANGE_RED_DOWNLOAD_DELAY=1
ORANGE_RED_AUTOTHROTTLE=true
ORANGE_RED_OBEY_ROBOTS=true
ORANGE_RED_REQUEST_TIMEOUT=30
ORANGE_RED_RETRY_TIMES=2
ORANGE_RED_MAX_RESOURCE_BYTES=26214400
ORANGE_RED_CHAT_THRESHOLD=0.70
GIT_USERNAME="Your Name"
GIT_EMAIL="your.email@example.com"
# Optional Copilot CLI BYOK helper keys for development tooling, not orange-red runtime.
